// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// ENUMS
//////////////////////////

enum QuestionType {
  radio
  checkbox
  input
  slider
  carousel
}

enum StepType {
  question
  form
}

enum PropertyType {
  residential
  commercial
}

//////////////////////////
// MODELS
//////////////////////////

model Step {
  id    Int    @id @default(autoincrement())
  title String
  order Int

  type StepType @default(question)

  question Question?

  createdAt DateTime @default(now())

  @@unique([order])
}

model Question {
  id   Int          @id @default(autoincrement())
  text String
  type QuestionType

  stepId Int  @unique
  step   Step @relation(fields: [stepId], references: [id], onDelete: Cascade)

  imageUrl String?

  options Option[]

  // базовые значения (fallback)
  min          Int?
  max          Int?
  stepValue    Int?
  defaultValue Int?

  isRequired Boolean @default(true)

  createdAt DateTime @default(now())

  answers Answer[]

  sliderConfigs SliderConfig[]
}

//////////////////////////
// 🔥 OPTION
//////////////////////////

model Option {
  id   Int    @id @default(autoincrement())
  text String

  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // 👇 ключевая логика
  propertyType PropertyType?

  createdAt DateTime @default(now())

  answers       Answer[]
  sliderConfigs SliderConfig[]
}

//////////////////////////
// 🔥 СЛАЙДЕР
//////////////////////////

model SliderConfig {
  id Int @id @default(autoincrement())

  // для какого вопроса (где показывается слайдер)
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // от какого ответа зависит (Студия / Дом / Квартира)
  optionId Int
  option   Option @relation(fields: [optionId], references: [id], onDelete: Cascade)

  min  Int
  max  Int
  step Int

  defaultValue Int?

  @@unique([questionId, optionId])
}

//////////////////////////
// SUBMISSION
//////////////////////////

model Submission {
  id Int @id @default(autoincrement())

  name    String
  phone   String
  email   String
  comment String?

  consent Boolean

  createdAt DateTime @default(now())

  answers Answer[]
}

//////////////////////////
// ANSWER
//////////////////////////

model Answer {
  id Int @id @default(autoincrement())

  submissionId Int
  questionId   Int

  optionId    Int?
  value       String?
  numberValue Int?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])
  option     Option?    @relation(fields: [optionId], references: [id])

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@index([questionId])
}
