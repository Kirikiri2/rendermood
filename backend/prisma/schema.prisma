// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// ENUMS
//////////////////////////

enum QuestionType {
  radio
  checkbox
  input
  slider
  carousel
}

enum StepType {
  question
  form
}

//////////////////////////
// MODELS
//////////////////////////

model Step {
  id    Int    @id @default(autoincrement())
  title String
  order Int

  type StepType @default(question)

  question Question?

  createdAt DateTime @default(now())

  @@unique([order])
}

model Question {
  id   Int          @id @default(autoincrement())
  text String
  type QuestionType

  stepId   Int      @unique
  step     Step     @relation(fields: [stepId], references: [id], onDelete: Cascade)
  imageUrl String?
  // варианты ответа (radio / checkbox)
  options  Option[]

  // настройки для slider
  min          Int?
  max          Int?
  stepValue    Int?
  defaultValue Int?

  // обязательность вопроса
  isRequired Boolean @default(true)

  createdAt DateTime @default(now())

  answers Answer[]
}

model Option {
  id   Int    @id @default(autoincrement())
  text String

  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  answers Answer[]
}

model Submission {
  id      Int     @id @default(autoincrement())
  // КОНТАКТЫ
  name    String // ФИО — обязательно
  phone   String // телефон — обязательно
  email   String // email — обязательно
  comment String?

  // СОГЛАСИЕ
  consent Boolean

  // pageUrl     String?
  // utmSource   String?
  // utmMedium   String?
  // utmCampaign String?
  // utmTerm     String?
  // utmContent  String?

  // userAgent String?
  // ipAddress String?

  // СИСТЕМА
  createdAt DateTime @default(now())

  answers Answer[]
}

model Answer {
  id Int @id @default(autoincrement())

  submissionId Int
  questionId   Int

  // для radio / checkbox
  optionId Int?

  // для input
  value String?

  // для slider
  numberValue Int?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])
  option     Option?    @relation(fields: [optionId], references: [id])

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@index([questionId])
}
